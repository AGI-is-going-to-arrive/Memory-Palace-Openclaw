# Memory Palace - Configuration
#
# Recommended: use the setup command instead of editing this file manually.
#   python3 scripts/openclaw_memory_palace.py setup --profile b   # hybrid/hash (zero-dep)
#   python3 scripts/openclaw_memory_palace.py setup --profile c   # hybrid/api + reranker
#   python3 scripts/openclaw_memory_palace.py setup --profile d   # hybrid/api + reranker + LLM
#
# Profile quick reference:
#   A = keyword / none          (plaintext only)
#   B = hybrid  / hash / dim=64 (zero external dependency, default)
#   C = hybrid  / api  + reranker enabled (+ optional shared LLM assists when configured)
#   D = hybrid  / api  + reranker enabled + shared LLM assists (write guard / compact gist / intent)

# ── Core (all profiles) ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/memory_palace/demo.db
SEARCH_DEFAULT_MODE=hybrid
RETRIEVAL_EMBEDDING_BACKEND=hash
RETRIEVAL_EMBEDDING_DIM=64
VALID_DOMAINS=core,writer,game,notes
MCP_API_KEY=

# ── Embedding (Profile C/D) ─────────────────────────────────────────
RETRIEVAL_EMBEDDING_MODEL=Qwen3-Embedding-8B
RETRIEVAL_EMBEDDING_API_BASE=
RETRIEVAL_EMBEDDING_API_KEY=
RETRIEVAL_REMOTE_TIMEOUT_SEC=8

# ── Reranker (Profile C/D) ──────────────────────────────────────────
RETRIEVAL_RERANKER_ENABLED=false
RETRIEVAL_RERANKER_API_BASE=
RETRIEVAL_RERANKER_API_KEY=
RETRIEVAL_RERANKER_MODEL=Qwen3-Reranker-8B
RETRIEVAL_RERANKER_TIMEOUT_SEC=8
RETRIEVAL_RERANKER_WEIGHT=0.25

# ── Shared LLM input accepted by setup/onboarding (Profile D target) ──────────────────
# setup/onboarding can accept one shared LLM tuple and fan it out to
# WRITE_GUARD / COMPACT_GIST / INTENT on apply.
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=replace-with-your-llm-model

# Profile D is only ready when the final resolved WRITE_GUARD_*, COMPACT_GIST_*,
# and INTENT_* fields below are all non-placeholder and your real checks pass.
# If you edit this file manually instead of using setup/onboarding, explicitly
# fill the resolved fields below too.

# ── LLM for Write Guard / Compact Gist (expected on Profile D; optional on C) ──────────────────
WRITE_GUARD_LLM_ENABLED=false
WRITE_GUARD_LLM_API_BASE=
WRITE_GUARD_LLM_API_KEY=
WRITE_GUARD_LLM_MODEL=replace-with-your-llm-model
COMPACT_GIST_LLM_ENABLED=false
COMPACT_GIST_LLM_API_BASE=
COMPACT_GIST_LLM_API_KEY=
COMPACT_GIST_LLM_MODEL=replace-with-your-llm-model

# ── Intent LLM (experimental, shared assist surface: optional on C, expected on D) ──────────────────
INTENT_LLM_ENABLED=false
INTENT_LLM_API_BASE=
INTENT_LLM_API_KEY=
INTENT_LLM_MODEL=replace-with-your-llm-model

# ── Write Guard Score Normalization (Profile C/D auto-enabled) ──────
# Auto-derived from RETRIEVAL_EMBEDDING_BACKEND: true for api/router/openai, false for hash.
# Override only if you need to force a specific value.
# WRITE_GUARD_SCORE_NORMALIZATION=true
# WRITE_GUARD_NORMALIZATION_FLOOR=0.85
# WRITE_GUARD_CROSS_CHECK_ADD_FLOOR=0.10

# LLM-based content-diff rescue for borderline UPDATE/ADD cases (default: off)
# Requires WRITE_GUARD_LLM_ENABLED=true to take effect.
# WRITE_GUARD_LLM_DIFF_RESCUE_ENABLED=false

# ── Compact Gist Timeout ────────────────────────────────────────────
# Reasoning models may need longer inference time (default: 45 seconds)
# COMPACT_GIST_TIMEOUT_SEC=45

# ── External Import (off by default) ─────────────────────────────────
EXTERNAL_IMPORT_ENABLED=false
EXTERNAL_IMPORT_ALLOWED_ROOTS=
EXTERNAL_IMPORT_ALLOWED_EXTS=.md,.txt,.json
EXTERNAL_IMPORT_MAX_TOTAL_BYTES=5242880
EXTERNAL_IMPORT_MAX_FILES=200

# ── Auto Learn (off by default) ─────────────────────────────────────
AUTO_LEARN_EXPLICIT_ENABLED=false
AUTO_LEARN_ALLOWED_DOMAINS=notes
AUTO_LEARN_REQUIRE_REASON=true

# ── Embedding Provider Chain (off by default) ────────────────────────
EMBEDDING_PROVIDER_CHAIN_ENABLED=false
EMBEDDING_PROVIDER_FAIL_OPEN=false
EMBEDDING_PROVIDER_FALLBACK=hash

# ── SQLite-vec / Vector Engine (off by default) ─────────────────────
RETRIEVAL_SQLITE_VEC_ENABLED=false
RETRIEVAL_SQLITE_VEC_EXTENSION_PATH=
RETRIEVAL_VECTOR_ENGINE=legacy
RETRIEVAL_SQLITE_VEC_READ_RATIO=0

# ── Runtime Write / WAL (off by default) ─────────────────────────────
RUNTIME_WRITE_WAL_ENABLED=false
RUNTIME_WRITE_JOURNAL_MODE=delete
RUNTIME_WRITE_WAL_SYNCHRONOUS=normal
RUNTIME_WRITE_BUSY_TIMEOUT_MS=120
RUNTIME_WRITE_WAL_AUTOCHECKPOINT=1000

# ── Runtime Flush Tracker defaults ───────────────────────────────────
# RUNTIME_FLUSH_HIGH_VALUE_EARLY_ENABLED=true
# RUNTIME_FLUSH_HIGH_VALUE_MIN_EVENTS=2
# RUNTIME_FLUSH_HIGH_VALUE_MIN_CHARS=120
# RUNTIME_FLUSH_HIGH_VALUE_MIN_CHARS_CJK=100

# ── API security ─────────────────────────────────────────────────────
# WARNING: For local development only. MUST be disabled in production.
# When enabled without MCP_API_KEY, all loopback requests skip authentication.
MCP_API_KEY_ALLOW_INSECURE_LOCAL=false
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# For the full list of advanced tuning knobs (search weights, MMR,
# vitality, WAL, feature gates, etc.), see the source defaults in
# backend/ or run: grep -rn 'os\.getenv\|_env_bool\|_env_int\|_env_float' backend/
